n = int(input())
months = [0, 31,28,31,30,31,30,31,31,30,31,30,31]
start_day = (sum(months[1:n]) % 7 + 4) % 7

print(f"{n:10d}월")
print("일 월 화 수 목 금 토")

print("   " * start_day, end="")

for day in range(1, months[n] + 1) :
    print(f"{day:2d}", end=" ")

    if (start_day + day) % 7 == 0 :
        print()
